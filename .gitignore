# ========================
# VisageAI - .gitignore
# ========================

# ── Python ──────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.pyo
.Python

# ── Virtual Environments ─────────────────────
venv/
.venv/
env/
ENV/
.env/

# ── Environment Variables / Secrets ──────────
.env
.env.*
*.env
!*.env.example

# ── Large AI Model Files (too big for GitHub) ─
*.onnx
*.tflite
*.pb
*.h5
*.pt
*.pth
*.weights
*.caffemodel
Models/

# ── Node / Frontend ──────────────────────────
attendance-ui/node_modules/
attendance-ui/.next/
attendance-ui/out/
attendance-ui/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Logs ─────────────────────────────────────
logs/
*.log
output.json

# ── Database ─────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── OS & Editor ──────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ── Test / Debug scripts ─────────────────────
test_*.py
check_*.py
/home/adithyan/PycharmProjects/SMAP/test_nchw.py
/home/adithyan/PycharmProjects/SMAP/test_variance.py

# ── Misc ──────────────────────────────────────
*.DS_Store
.cache/
.pytest_cache/
.mypy_cache/
coverage/
.coverage
htmlcov/

# ── Backend upload / temp dirs ────────────────
backend/enrollment_temp/
backend/uploads/
AI-Attendance-System/enrollment_temp/

# ── Stale scratch files ───────────────────────
*.new
*.bak
*.orig

# ── AI-Attendance-System local env ───────────
AI-Attendance-System/.env
